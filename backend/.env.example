# Copy this file to .env and fill in real values. Never commit .env.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API → JWT Secret (optional — used only for HS256 fallback)
SUPABASE_JWT_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
# Project Settings → Database → Connection string (Transaction pooler recommended)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Encryption ───────────────────────────────────────────────────────────────
# 32-byte key as 64 hex chars — used to encrypt Gmail refresh tokens at rest
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Google OAuth (for Gmail connect) ─────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → Web client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gemini (optional — LLM fallback categorisation) ──────────────────────────
# Leave blank to disable; transactions fall back to keyword categorisation
GEMINI_API_KEY=

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# Path to Firebase service account JSON (downloaded from Firebase Console)
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
# Alternatively, inline the JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
GMAIL_SYNC_INTERVAL_MINUTES=15
